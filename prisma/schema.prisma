datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String

  bases     UserBase[]
}

model Base {
  id        String   @id @default(uuid())
  name      String
  code      String
  password  String

  users     UserBase[]
  inventory Inventory[]
}

model UserBase {
  id      String @id @default(uuid())

  userId  String
  baseId  String
  role    String

  user User @relation(fields: [userId], references: [id])
  base Base @relation(fields: [baseId], references: [id])
}

model Product {
  id    String @id @default(uuid())
  name  String
  sku   String
  stock Int

  inventory Inventory[]
}

model Inventory {
  id        String @id @default(uuid())

  productId String
  baseId    String
  quantity  Int

  product Product @relation(fields: [productId], references: [id])
  base    Base    @relation(fields: [baseId], references: [id])
}